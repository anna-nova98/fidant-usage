datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-py"
}

model User {
  id        Int     @id @default(autoincrement())
  name      String?
  plan_tier String  @default("starter")  
}

model Request {
  id         Int    @id @default(autoincrement())
  user_id    Int
  date_key   String   
  request_id String   
  status     String   
}