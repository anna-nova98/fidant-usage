generator client {
  provider  = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider = "sqlite"
}

model Request {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  user_id   Int
  createdAt DateTime @default(now())
}


model daily_usage_cache {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique
  total_usage Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
