generator client {
  provider  = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Required models — do not modify structure, removed @db.VarChar as SQLite does not support native types
model users {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  plan_tier  String   @default("starter")
  created_at DateTime @default(now())
}

model daily_usage_events {
  id           Int       @id @default(autoincrement())
  user_id      Int
  date_key     String    // "YYYY-MM-DD"
  request_id   String
  status       String    // "reserved" | "committed"
  reserved_at  DateTime  @default(now())
  committed_at DateTime?
  created_at   DateTime  @default(now())
}

// Cache table for precomputed daily aggregates per user per day.
// Avoids scanning raw events on every stats request.
model daily_usage_cache {
  id               Int      @id @default(autoincrement())
  user_id          Int
  date_key         String   // "YYYY-MM-DD"
  committed_count  Int
  reserved_count   Int
  computed_at      DateTime @default(now())

  @@unique([user_id, date_key])
}
